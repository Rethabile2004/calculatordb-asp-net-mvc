@model CalculatorAppDB.Models.Calc

@{
    ViewData["Title"] = "Create";
}
@if (ViewBag.ShowAdd == true)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage<a asp-action="Index">Back to List</a></div>
}
<h4>New calculator Info</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="SerialNr" class="control-label"></label>
                <input asp-for="SerialNr" class="form-control" />
                <span asp-validation-for="SerialNr" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Make" class="control-label"></label>
                <input asp-for="Make" class="form-control" />
                <span asp-validation-for="Make" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Model" class="control-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Functions" class="control-label"></label>
                <input asp-for="Functions" class="form-control" />
                <span asp-validation-for="Functions" class="text-danger"></span>
            </div>
             @*ViewBag.ShowAdd used to control visibility of the "Add" button*@
            @if (ViewBag.ShowAdd == false)
            {
                <div class="form-group">
                    <input type="submit" value="Add" class="btn btn-primary" />
                </div>
            }
        </form>
    </div>
</div>
@*ViewBag.ShowAdd used to control visibility of the "Back to List"*@
@if (ViewBag.ShowAdd == false)
{
    <div>
        <a asp-action="Index">Back to List</a>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
