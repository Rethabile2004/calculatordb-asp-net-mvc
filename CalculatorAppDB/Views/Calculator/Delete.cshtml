@model CalculatorAppDB.Models.Calc

@{
    ViewData["Title"] = "Delete";
}

@*ViewBag.SuccessMessage used to determine if the success message should be displayed*@
@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage<a asp-action="Index">Back to List</a></div>
}

<h4>Are you sure you want to delete this calculator?</h4>
<hr/>
<div>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Make)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Make)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Model)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Model)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Functions)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Functions)
        </dd>
    </dl>
    @*ViewBag.ShowDelete used to control visibility of the "Delete" button*@
    @if (ViewBag.ShowDelete == true)
    {
        <form asp-action="Delete">
            @Html.HiddenFor(model => model.SerialNr)
            <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
    }
</div>
